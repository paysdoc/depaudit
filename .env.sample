# Socket.dev API token for supply-chain risk scanning
# Get yours at https://socket.dev/dashboard
SOCKET_API_TOKEN=

# Override Socket.dev base URL (default: https://api.socket.dev) — used by tests against a mock server
# SOCKET_API_BASE_URL=

# Slack Incoming Webhook URL for gate failure notifications
# Create one at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=
